# Ghana Savings & Loans — Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to git — it is in .gitignore.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_VERSION=1.0.0
APP_PORT=8000
UVICORN_WORKERS=4

# ── Institution (from BoG licence certificate) ───────────────────────────────
INSTITUTION_NAME="Your Institution Name"
BOG_LICENCE_NUMBER=MFI-000000/2024
GHANA_DATA_REGION=gh-accra-1

# ── Security (generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
SECRET_KEY=change-me-to-a-strong-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin Seed Account ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourinstitution.com.gh
ADMIN_PASSWORD=Change@Me1234!

# ── Database (PostgreSQL 15+) ─────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://gsl:yourpassword@localhost:5432/gsl_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── CORS Origins ──────────────────────────────────────────────────────────────
# Comma-separated. Include all frontend domains.
ALLOWED_ORIGINS=http://localhost:3000,https://portal.yourinstitution.com.gh

# ── GhIPSS Mobile Money Interoperability Interface ────────────────────────────
# Obtain from GhIPSS: https://www.ghipss.net
GHIPSS_API_KEY=your-ghipss-api-key
GHIPSS_API_SECRET=your-ghipss-api-secret
GHIPSS_INSTITUTION_CODE=your-mfi-code
MOCK_GHIPSS=true   # Set false in production

# ── Credit Bureaus (L.I. 2394) ────────────────────────────────────────────────
# XDS Data Ghana: https://www.xdsdata.com.gh
XDS_API_KEY=your-xds-api-key
XDS_API_URL=https://api.xds.com.gh/v2

# D&B Ghana: https://www.dnb.com/gh
DB_GHANA_API_KEY=your-db-ghana-api-key
DB_GHANA_API_URL=https://api.dnb.com/gh/v1

# MyCredit Score Ghana: https://www.mycreditscore.com.gh
MY_CREDIT_API_KEY=your-mycredit-api-key
MY_CREDIT_API_URL=https://api.mycreditscore.com.gh/v1

MOCK_CREDIT_BUREAUS=true   # Set false in production

# ── Ghana Card / NIA API ──────────────────────────────────────────────────────
# Obtain from National Identification Authority: https://www.nia.gov.gh
GHANA_CARD_API_URL=https://api.nia.gov.gh/v1
GHANA_CARD_API_KEY=your-nia-api-key
MOCK_GHANA_CARD_API=true   # Set false in production

# ── Payment Gateways ──────────────────────────────────────────────────────────
# Paystack: https://paystack.com
PAYSTACK_SECRET_KEY=sk_live_your_paystack_key

# Flutterwave: https://flutterwave.com
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE_your_key

# expressPay Ghana: https://expresspaygh.com
EXPRESS_PAY_MERCHANT_ID=your-merchant-id
EXPRESS_PAY_API_KEY=your-exprespay-key

# Hubtel: https://hubtel.com
HUBTEL_CLIENT_ID=your-hubtel-id
HUBTEL_CLIENT_SECRET=your-hubtel-secret

DEFAULT_PAYMENT_GATEWAY=PAYSTACK

# ── SMS / USSD ────────────────────────────────────────────────────────────────
# mNotify: https://mnotify.com
MNOTIFY_API_KEY=your-mnotify-key
MNOTIFY_SENDER_ID=YOURNAME

# ── FIC Reporting (AML Act 1044) ──────────────────────────────────────────────
FIC_SUBMISSION_URL=https://portal.fic.gov.gh/api/v1
FIC_API_KEY=your-fic-api-key
FIC_REPORTING_OFFICER=compliance@yourinstitution.com.gh

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Sentry (error tracking) ───────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Compliance Thresholds (do not modify without BoG approval) ───────────────
CTR_THRESHOLD_GHS=10000.00
COMPLAINT_RESOLUTION_SLA_DAYS=20
